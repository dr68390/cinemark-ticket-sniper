#!/bin/bash
# Alert channel: file a GitHub issue (GitHub then emails the @mentioned owner).
# Called by watch.py as: notify-hook TITLE MESSAGE
# Only acts on GitHub Actions runners; local runs rely on the macOS banner.
set -euo pipefail
[ "${GITHUB_ACTIONS:-}" = "true" ] || exit 0

TITLE="$1"
MESSAGE="$2"
BODY="@danielrousseaug ${MESSAGE}

Book: https://www.cinemark.com/theatres/tx-dallas/cinemark-dallas-xd-and-imax

_automated alert from the odyssey seat watcher_"

gh issue create \
  --repo "${GITHUB_REPOSITORY}" \
  --title "🎬 ${TITLE}" \
  --body "${BODY}"
